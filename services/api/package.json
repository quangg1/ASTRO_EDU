{
  "name": "@galaxies/api",
  "version": "1.0.0",
  "private": true,
  "description": "Galaxies unified API (auth, courses, tutorials, payment, community, media)",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "test": "node --test",
    "sync:learning-path": "node scripts/sync-learning-path-modules-from-json.js",
    "export:concepts-json": "node scripts/export-concepts-json.js --out data/concepts.json",
    "build:concept-prerequisites": "node scripts/build-concept-prerequisites.js --dry-run",
    "build:concept-prerequisites:openrouter": "node scripts/build-concept-prerequisites.js --dry-run --provider openrouter",
    "build:concept-prerequisites:openrouter:free-all": "node scripts/build-concept-prerequisites.js --dry-run --provider openrouter --use-all-free-models",
    "apply:concept-prerequisites": "node scripts/build-concept-prerequisites.js --apply",
    "patch:topic-weights-json": "node scripts/patch-learning-path-topic-weights.js",
    "crawl-news": "node scripts/crawl-news.js",
    "purge-news": "node scripts/purge-news-posts.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@galaxies/auth-shared": "file:../../packages/auth-shared",
    "@mozilla/readability": "^0.6.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "firebase-admin": "^13.0.0",
    "jsdom": "^25.0.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.10.1",
    "rss-parser": "^3.13.0"
  }
}
